#!/usr/bin/env bash
set -euo pipefail

scrub_git_local_env() {
  local vars
  local var
  vars="$(git rev-parse --local-env-vars)"
  while IFS= read -r var; do
    if [[ -n "$var" ]]; then
      unset "$var"
    fi
  done <<<"$vars"
}

top_level="$(git rev-parse --show-toplevel)"

if sccache_bin="$(command -v sccache)"; then
  export RUSTC_WRAPPER="$sccache_bin"
  export CARGO_BUILD_RUSTC_WRAPPER="$sccache_bin"

  if [[ -z "${SCCACHE_DIR:-}" || "${SCCACHE_DIR:-}" == /home/wrix/* ]]; then
    export SCCACHE_DIR="$top_level/.loom/sccache"
  fi

  mkdir -p "$SCCACHE_DIR"
fi

scrub_git_local_env
exec cargo run --bin loom --manifest-path "$top_level/Cargo.toml" -- "$@"
