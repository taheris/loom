#!/usr/bin/env bash
set -euo pipefail

find_real_wrix() {
  local script_path
  script_path="$(realpath "${BASH_SOURCE[0]}")"

  local path_entries
  IFS=':' read -r -a path_entries <<< "${PATH:-}"

  local entry candidate resolved
  for entry in "${path_entries[@]}"; do
    [[ -n "$entry" ]] || entry="."
    candidate="$entry/wrix"
    if [[ -x "$candidate" ]]; then
      resolved="$(realpath "$candidate")"
      if [[ "$resolved" != "$script_path" ]]; then
        printf '%s\n' "$candidate"
        return 0
      fi
    fi
  done

  return 1
}

workspace_root() {
  local root
  if ! root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    printf "wrix beads push: cannot resolve a git repository from '%s' — run inside a workspace checkout\n" "$PWD" >&2
    return 1
  fi

  case "$root" in
    */.git/beads-worktrees/*)
      printf '%s\n' "${root%%/.git/beads-worktrees/*}"
      ;;
    *)
      printf '%s\n' "$root"
      ;;
  esac
}

sync_branch() {
  local root config branch
  root="$1"
  config="$root/.beads/config.yaml"
  if [[ ! -f "$config" ]]; then
    printf 'beads\n'
    return 0
  fi

  branch="$(awk -F: '/^[[:space:]]*sync-branch[[:space:]]*:/ { gsub(/[[:space:]"]/, "", $2); print $2; exit }' "$config")"
  if [[ -n "$branch" ]]; then
    printf '%s\n' "$branch"
  else
    printf 'beads\n'
  fi
}

sql_quote() {
  local value
  value="${1//\'/\'\'}"
  printf "'%s'" "$value"
}

repair_dolt_origin_remote() {
  local root worktree_remote_dir
  root="$1"
  worktree_remote_dir="$2"

  if [[ -n "${IS_SANDBOX:-}" || "$root" == /workspace* || ! -d "$worktree_remote_dir" ]]; then
    return 0
  fi

  local remote list origin add_sql
  remote="file://$worktree_remote_dir"
  if list="$(bd dolt remote list 2>/dev/null)"; then
    origin="$(awk '$1 == "origin" { print $2; exit }' <<< "$list")"
  else
    origin=""
  fi
  if [[ "$origin" == "$remote" ]]; then
    return 0
  fi

  printf 'wrix beads push: repairing Dolt origin remote -> %s\n' "$remote" >&2
  if [[ -n "$origin" ]]; then
    bd sql "CALL DOLT_REMOTE('remove', 'origin')"
  fi
  add_sql="CALL DOLT_REMOTE('add', 'origin', $(sql_quote "$remote"))"
  bd sql "$add_sql"
}

is_fast_forward_rejection() {
  local text
  text="$(tr '[:upper:]' '[:lower:]' <<< "$1")"
  [[ "$text" == *non-fast-forward* \
    || "$text" == *fast-forward* \
    || "$text" == *reject* \
    || "$text" == *behind* \
    || "$text" == *'out of date'* \
    || "$text" == *denied* ]]
}

affected_ids_sql() {
  cat <<'SQL'
SELECT DISTINCT id FROM (
  SELECT to_id AS id
  FROM dolt_commit_diff_issues
  WHERE to_commit = 'HEAD' AND from_commit = 'remotes/origin/main'
    AND (from_status IS NULL OR from_status <> to_status)
  UNION
  SELECT to_issue_id AS id
  FROM dolt_commit_diff_labels
  WHERE to_commit = 'HEAD' AND from_commit = 'remotes/origin/main'
  UNION
  SELECT from_issue_id AS id
  FROM dolt_commit_diff_labels
  WHERE to_commit = 'HEAD' AND from_commit = 'remotes/origin/main'
) AS touched
WHERE id IS NOT NULL
SQL
}

query_affected_ids() {
  local output
  output="$(bd sql --csv "$(affected_ids_sql)")"
  tail -n +2 <<< "$output" | awk 'NF { print $1 }'
}

snapshot_query_for_ids() {
  local id quoted joined
  joined=""
  for id in "$@"; do
    quoted="$(sql_quote "$id")"
    if [[ -n "$joined" ]]; then
      joined="$joined,$quoted"
    else
      joined="$quoted"
    fi
  done
  printf "SELECT i.id, i.status, COALESCE((SELECT GROUP_CONCAT(label ORDER BY label SEPARATOR ',') FROM labels WHERE issue_id = i.id), '') AS labels FROM issues i WHERE i.id IN (%s) ORDER BY i.id" "$joined"
}

pull_with_intent_protection() {
  local ids snapshot_query intent post push_output push_status
  mapfile -t ids < <(query_affected_ids)
  if [[ "${#ids[@]}" -eq 0 ]]; then
    bd dolt pull
    bd dolt push
    return 0
  fi

  snapshot_query="$(snapshot_query_for_ids "${ids[@]}")"
  intent="$(bd sql --csv "$snapshot_query")"
  bd dolt pull
  post="$(bd sql --csv "$snapshot_query")"
  if [[ "$intent" != "$post" ]]; then
    printf 'wrix beads push: pull-fallback diverged from local status/label intent; refusing to push\n' >&2
    printf 'wrix beads push: affected issue IDs: %s\n' "${ids[*]}" >&2
    return 1
  fi

  set +e
  push_output="$(bd dolt push 2>&1)"
  push_status=$?
  set -e
  if [[ -n "$push_output" ]]; then
    printf '%s\n' "$push_output" >&2
  fi
  return "$push_status"
}

sync_dolt_remote() {
  local commit_output push_output push_status

  set +e
  commit_output="$(bd dolt commit 2>&1)"
  set -e
  if [[ -n "$commit_output" ]]; then
    printf '%s\n' "$commit_output" >&2
  fi

  set +e
  push_output="$(bd dolt push 2>&1)"
  push_status=$?
  set -e
  if [[ -n "$push_output" ]]; then
    printf '%s\n' "$push_output" >&2
  fi
  if [[ "$push_status" -eq 0 ]]; then
    return 0
  fi
  if is_fast_forward_rejection "$push_output"; then
    pull_with_intent_protection
    return
  fi
  return "$push_status"
}

ensure_beads_worktree() {
  local root branch worktree origin_branch
  root="$1"
  branch="$2"
  worktree="$3"

  if [[ -d "$worktree" ]] && PREK_ALLOW_NO_CONFIG=1 git -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return 0
  fi
  if [[ -d "$worktree" ]]; then
    PREK_ALLOW_NO_CONFIG=1 git -C "$root" worktree prune
    rm -rf "$worktree"
  fi

  if PREK_ALLOW_NO_CONFIG=1 git -C "$root" rev-parse --verify "$branch" >/dev/null 2>&1; then
    PREK_ALLOW_NO_CONFIG=1 git -C "$root" worktree add "$worktree" "$branch" --quiet
    return 0
  fi

  origin_branch="origin/$branch"
  if PREK_ALLOW_NO_CONFIG=1 git -C "$root" rev-parse --verify "$origin_branch" >/dev/null 2>&1; then
    PREK_ALLOW_NO_CONFIG=1 git -C "$root" worktree add "$worktree" "$origin_branch" --quiet
    return 0
  fi

  printf "wrix beads push: no '%s' branch found; skipping GitHub sync\n" "$branch" >&2
  return 2
}

repair_worktree_pointers() {
  local root branch worktree dotgit admin current
  root="$1"
  branch="$2"
  worktree="$3"
  dotgit="$worktree/.git"
  admin="$root/.git/worktrees/$branch"

  if [[ ! -f "$dotgit" || ! -d "$admin" ]]; then
    return 0
  fi
  current="$(sed -n 's/^gitdir: //p' "$dotgit" | head -n 1)"
  if [[ -n "$current" && ! -d "$current" ]]; then
    printf 'gitdir: %s\n' "$admin" > "$dotgit"
    printf '%s/.git\n' "$worktree" > "$admin/gitdir"
  fi
}

commit_dirty_worktree() {
  local worktree status
  worktree="$1"
  status="$(PREK_ALLOW_NO_CONFIG=1 git -C "$worktree" status --porcelain --untracked-files=normal)"
  if [[ -z "$status" ]]; then
    return 0
  fi
  PREK_ALLOW_NO_CONFIG=1 git -C "$worktree" add -A
  PREK_ALLOW_NO_CONFIG=1 git -C "$worktree" commit --no-verify -m 'bd sync' --quiet
}

sync_beads_git_branch() {
  local root branch git_dir worktree remote_dir worktree_remote_dir source destination ensure_status
  root="$1"
  branch="$2"
  git_dir="$(PREK_ALLOW_NO_CONFIG=1 git -C "$root" rev-parse --path-format=absolute --git-common-dir)"
  worktree="$git_dir/beads-worktrees/$branch"
  remote_dir="$root/.beads/dolt/dolt-remote"
  worktree_remote_dir="$worktree/.beads/dolt-remote"

  repair_dolt_origin_remote "$root" "$worktree_remote_dir"
  set +e
  ensure_beads_worktree "$root" "$branch" "$worktree"
  ensure_status=$?
  set -e
  if [[ "$ensure_status" -eq 2 ]]; then
    return 0
  fi
  if [[ "$ensure_status" -ne 0 ]]; then
    return "$ensure_status"
  fi

  repair_worktree_pointers "$root" "$branch" "$worktree"
  commit_dirty_worktree "$worktree"
  PREK_ALLOW_NO_CONFIG=1 git -C "$worktree" pull --rebase --quiet

  if [[ -d "$remote_dir" ]]; then
    source="$remote_dir/"
    destination="$worktree_remote_dir/"
    mkdir -p "$worktree_remote_dir"
    rsync -a --delete "$source" "$destination"
  fi

  commit_dirty_worktree "$worktree"
  PREK_ALLOW_NO_CONFIG=1 git -C "$worktree" push --no-verify -u origin "$branch" --quiet
  printf 'wrix beads push: synced to GitHub\n'
}

run_beads_push() {
  if [[ -n "${LOOM_INSIDE:-}" ]]; then
    printf 'wrix beads push: LOOM_INSIDE set; loom driver owns publish, skipping\n' >&2
    return 0
  fi

  local root branch
  root="$(workspace_root)"
  branch="$(sync_branch "$root")"
  cd "$root"
  bd config set export.auto false
  sync_dolt_remote
  sync_beads_git_branch "$root" "$branch"
}

if [[ "${1:-}" == "beads" && "${2:-}" == "push" ]]; then
  shift 2
  if [[ "$#" -ne 0 ]]; then
    printf 'wrix beads push: unexpected arguments: %s\n' "$*" >&2
    exit 2
  fi
  run_beads_push
  exit 0
fi

if real_wrix="$(find_real_wrix)"; then
  exec "$real_wrix" "$@"
fi

printf 'wrix: command not found outside the devshell; repo-local fallback supports only wrix beads push\n' >&2
exit 127
