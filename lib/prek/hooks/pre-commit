#!/usr/bin/env bash
set -euo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lock.sh
. "${HOOK_DIR}/../lock.sh"

if ! command -v prek >/dev/null 2>&1; then
    echo "prek pre-commit: prek missing on PATH" >&2
    exit 1
fi

_prek_acquire_lock
exec prek hook-impl --hook-type=pre-commit --no-progress "$@"
