#!/usr/bin/env bash
set -euo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lock.sh
. "${HOOK_DIR}/../lock.sh"

if ! command -v prek >/dev/null 2>&1; then
    echo "prek pre-push: prek missing on PATH" >&2
    exit 1
fi

workspace_basename="$(basename "$(git worktree list --porcelain | awk '/^worktree / {print $2; exit}')")"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/loom/prek/${workspace_basename}"
stamp_file="${XDG_STATE_HOME:-$HOME/.local/state}/loom/prek/${workspace_basename}/push-verified"
head_sha="$(git rev-parse HEAD)"

_prek_acquire_lock

if [[ -f "$stamp_file" ]] && [[ "$(cat "$stamp_file")" == "$head_sha" ]]; then
    rm -f "$stamp_file"
    exit 0
fi

prek hook-impl --hook-type=pre-push --no-progress -- "$@" 9>&-

mkdir -p "$state_dir"
printf '%s\n' "$head_sha" > "$stamp_file"
